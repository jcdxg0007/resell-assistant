# 必填：backend 的 HTTPS 入口（不要带尾部斜杠）。
# 在 Sealos 控制台或 kubectl 里看 ingress: kubectl -n ns-3zn44u6p get ingress
# 用以 "network-" 开头的那个，例如 https://jbbobxkpstwp.sealosbja.site
BACKEND_BASE_URL=https://jbbobxkpstwp.sealosbja.site

# 必填：跟 backend .env 里的 PDD_WORKER_TOKEN 完全一致
WORKER_TOKEN=change-me-pdd-worker-token

# 本 worker 的名字（给运维用，区分多 worker 部署。一般一台够）
WORKER_NAME=windows-home

# 日志级别
LOG_LEVEL=INFO

# 长轮询单次最大阻塞秒数（不要超过 60，否则 HTTPS 连接可能被 LB 切断）
POLL_WAIT_SECONDS=25

# 心跳上报间隔
HEARTBEAT_INTERVAL_SECONDS=45

# 这台 worker 上当前 PDD APP 登录的账号 account_name（必填）。
# 两个用途：
#  1) audit/日志——backend 记录每个任务结果来自哪个号，出问题好复盘。
#  2) 多号路由（roadmap §15）——poll/心跳带这个号，backend 只把"分配给本号
#     品类"的自动跑批任务发给它，多号并发时品类画像互相隔离、不抢同一批词。
# 必须和 accounts 表里 platform='pdd_crawler' 的 account_name 完全一致。
# 换号时同步改这里 + 跑 backend/scripts/pdd_account_swap.py
BOUND_PDD_ACCOUNT=pdd_crawler_7315

# ── 阵发式任务调度（模拟真人搜购物 APP 的节奏）───────────────────────
#
# 注意：本节下面这些参数 + HUMANIZE_PACE 现在都可以从前端远程改了（存
# backend system_configs，worker 每个心跳周期 ≤45s 自动拉取热更新）。
# 这里的值只作为 worker 启动时的"初始默认"——前端从没改过时用这里的值；
# 前端改过任意参数后，那个参数以 backend 的值为准（覆盖本文件）。
# 详见 docs/PDD-自建采集-roadmap.md §"Day 4 调度参数远程配置"。
#
# 真人不是均匀的"每 30s 一次"，而是阵发性的：
#   想到一个需求 → 短时间内连搜 3-5 次（每次间 5-30s 思考）
#   → 离开几分钟到半小时 → 想到新需求再来一波
#
# 本节配置定义"小爆发 + 长静默"的具体范围。

# 单次 burst 内的搜索次数（从 [MIN, MAX] 随机抽）
# 2026-05-28 用户反馈：原 [1, 4] 下限太低，会出现"开一波只搜 1 次就歇 30 min"
# 的反真人节奏。改成 [3, 5] 匹配真人"一波查 3-5 个相关词"的搜索行为。
# 注意：burst_size 跟单次 dispatcher 派给 worker 的任务数无关——派单方
# 必须自己把 3-5 个任务**批量** enqueue，worker 才会在一个 burst 内连
# 着做完（否则隔得久 scheduler 会先 force-end burst 进静默期）。
# 见 backend/scripts/pdd_fire_keyword_batch.py 的批量派单写法。
BURST_SIZE_MIN=3
BURST_SIZE_MAX=5

# burst 内相邻两次搜索的间隔（秒）
# 5-30s 模拟"想下个关键词"的思考时间
INTRA_BURST_GAP_SECONDS_MIN=5
INTRA_BURST_GAP_SECONDS_MAX=30

# ── 全局浏览节奏因子 ─────────────────────────────────────────
# 1.0 = 原始节奏；0.7 = 整体快 30%（推荐想提速时用这个）。clamp 到 [0.3, 1.0]。
# 作用范围（只压"浏览 / 停留 / 翻页观察 / 想下个词"这类等待）：
#   - 搜索结果页屏间停留、lazy-render 微滚后的观察停留
#   - warmup 摸鱼的首页滚动间隔、详情页停留时长
#   - 善后 back 的间隔
#   - burst 内 intra-gap（5-30s → 0.7 时变 3.5-21s）
# **不影响**（反爬关键节奏，写死不随本因子变）：
#   - IME 每字输入节奏（太快是机器指纹）
#   - 冷启动等 PDD 起来 / splash（等 APP，不是浏览）
#   - 设备解锁流程的固定等待
#   - burst 间静默 5-30 min（账号画像关键）、daily quota
# 注意：worker (main.py) 和 client (pdd_app_client.py) 共用这一个变量，
# 改一处即全局生效。想再快可降到 0.6，但 < 0.5 滚动停留会短到看着像爬虫。
HUMANIZE_PACE=0.7

# 两个 burst 之间的静默期（分钟）
# 5-30 分钟。这段时间内 PDD 会被切到后台（KEYCODE_HOME），让账号画像
# 看起来更像"偶尔打开 APP 的真用户"而不是"全天蹲守的爬虫"
INTER_BURST_GAP_MINUTES_MIN=5
INTER_BURST_GAP_MINUTES_MAX=30

# 每天总搜索数硬上限。超过这个数后所有 search 任务立刻返回失败
# （risk_signals=["daily_quota_exhausted"]），到 UTC 0 点自动重置。
# 7315 这种新接入号建议先用 30；稳定一周后再放到 50-100
DAILY_SEARCH_QUOTA=30

# burst 内最后一次搜索后，多久没新任务就强制关 burst（按 home 退后台）。
# 每个 burst 开启时随机抽一个值，避免"搜完正好 60s 退桌面"成为统计指纹。
# 45-180s 范围模拟真人"看完结果到放下手机"的自然间隔（短的几乎立刻收，
# 长的可能停留 2-3 分钟看图/对比）。
# 注意：上限不宜超过 inter_gap MIN（5 min = 300s），否则可能出现 burst
# 还没关 inter_gap 计时已经"开始"的逻辑窗口（实际不会出问题，但难追踪）。
BURST_IDLE_TIMEOUT_SECONDS_MIN=45
BURST_IDLE_TIMEOUT_SECONDS_MAX=180

# 紧急任务旁路阈值：priority >= 这个值的任务跳过 inter-burst quiet（5-30 min
# 静默期），立刻开新 burst 处理；backend enqueue 也会用 LPUSH 把它插到队
# 首。普通 fire 默认 priority=1，远低于阈值。紧急 fire 用：
#   python -m scripts.pdd_fire_one_task "保温杯" --emergency
#   python -m scripts.pdd_fire_keyword_batch 保温杯 牙线 --emergency
# 必须与 backend 的同名配置保持一致（默认 8）。
EMERGENCY_PRIORITY_THRESHOLD=8

# ── 调试开关 ─────────────────────────────────────────────────
# DEBUG_DUMP_LAST_SEARCH_XML=1 时，search() 期间每屏的 PDD UI XML 会
# 自动保存到工作目录，文件名形如：dump_search_<关键词>_seq<屏序号>.xml
# 用于事后采样分析（如店铺名、SKU 痕迹定位）。生产环境默认关闭。
# DEBUG_DUMP_LAST_SEARCH_XML=1
