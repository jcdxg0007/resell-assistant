# 必填：backend 的 HTTPS 入口（不要带尾部斜杠）。
# 在 Sealos 控制台或 kubectl 里看 ingress: kubectl -n ns-3zn44u6p get ingress
# 用以 "network-" 开头的那个，例如 https://jbbobxkpstwp.sealosbja.site
BACKEND_BASE_URL=https://jbbobxkpstwp.sealosbja.site

# 必填：跟 backend .env 里的 PDD_WORKER_TOKEN 完全一致
WORKER_TOKEN=change-me-pdd-worker-token

# 本 worker 的名字（给运维用，区分多 worker 部署。一般一台够）
WORKER_NAME=windows-home

# 日志级别
LOG_LEVEL=INFO

# 长轮询单次最大阻塞秒数（不要超过 60，否则 HTTPS 连接可能被 LB 切断）
POLL_WAIT_SECONDS=25

# 心跳上报间隔
HEARTBEAT_INTERVAL_SECONDS=45

# 这台 worker 上当前 PDD APP 登录的账号 account_name（Phase 1 单设备阶段必填）。
# 仅作 audit/日志用途——worker 不切账号，PDD APP 实际登录的是谁就用谁，
# 这里只是让 backend 能记录每个任务结果来自哪个号，方便出问题复盘。
# 换号时同步改这里 + 跑 backend/scripts/pdd_account_swap.py
BOUND_PDD_ACCOUNT=pdd_crawler_7315

# ── 阵发式任务调度（模拟真人搜购物 APP 的节奏）───────────────────────
#
# 真人不是均匀的"每 30s 一次"，而是阵发性的：
#   想到一个需求 → 短时间内连搜 3-5 次（每次间 5-30s 思考）
#   → 离开几分钟到半小时 → 想到新需求再来一波
#
# 本节配置定义"小爆发 + 长静默"的具体范围。

# 单次 burst 内的搜索次数（从 [MIN, MAX] 随机抽）
# 2026-05-28 用户反馈：原 [1, 4] 下限太低，会出现"开一波只搜 1 次就歇 30 min"
# 的反真人节奏。改成 [3, 5] 匹配真人"一波查 3-5 个相关词"的搜索行为。
# 注意：burst_size 跟单次 dispatcher 派给 worker 的任务数无关——派单方
# 必须自己把 3-5 个任务**批量** enqueue，worker 才会在一个 burst 内连
# 着做完（否则隔得久 scheduler 会先 force-end burst 进静默期）。
# 见 backend/scripts/pdd_fire_keyword_batch.py 的批量派单写法。
BURST_SIZE_MIN=3
BURST_SIZE_MAX=5

# burst 内相邻两次搜索的间隔（秒）
# 5-30s 模拟"想下个关键词"的思考时间
INTRA_BURST_GAP_SECONDS_MIN=5
INTRA_BURST_GAP_SECONDS_MAX=30

# 两个 burst 之间的静默期（分钟）
# 5-30 分钟。这段时间内 PDD 会被切到后台（KEYCODE_HOME），让账号画像
# 看起来更像"偶尔打开 APP 的真用户"而不是"全天蹲守的爬虫"
INTER_BURST_GAP_MINUTES_MIN=5
INTER_BURST_GAP_MINUTES_MAX=30

# 每天总搜索数硬上限。超过这个数后所有 search 任务立刻返回失败
# （risk_signals=["daily_quota_exhausted"]），到 UTC 0 点自动重置。
# 7315 这种新接入号建议先用 30；稳定一周后再放到 50-100
DAILY_SEARCH_QUOTA=30
