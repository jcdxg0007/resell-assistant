# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.venv/
backend/.venv/

# Node
node_modules/
frontend/dist/

# Environment
.env
backend/.env

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Playwright
playwright_states/*.json
backend/playwright_states/

# Storage
backend/storage/images/*
!backend/storage/images/.gitkeep
kubectl
backend/celerybeat-schedule.db

# Runtime logs
backend/logs/
*.log

# Token / 临时凭据文件（防误提交）
_new_token.txt
temp_git_edit*

# 本地备份（scripts/backup_now.sh 输出，绝不进 git）
backups/
data_samples/
*.tar.gz
*.sql.gz

# worker 机器专属配置（serial/号），每台机一份，git pull 永不覆盖（roadmap §15.4）
worker/*.env.local.bat
# worker 运行时产生的调试 dump（别进 git）
worker/dump_*.xml
worker/dump_*.txt
worker/hits.txt
worker/tap_search_failed_*.xml
worker/_detail_spike/
